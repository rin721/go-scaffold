# 环境变量配置文件示例
# 将此文件复制为 .env 并填入实际值。
# .env 文件不应提交到 Git；生产环境建议直接使用系统环境变量或密钥管理服务。
#
# 命名策略：
# - 配置覆盖统一使用未加全局前缀的 <MODULE>_<FIELD>，例如 DB_HOST、SERVER_PORT。
# - 数据库旧变量 REI_APP_DB_* 仅作为兼容 fallback；新配置请使用 DB_*。
# - auth/JWT 当前为延后需求，不在本文件声明，避免暗示已实现能力。

# ==================== 数据库配置 ====================
# 数据库驱动类型 (postgres, mysql, sqlite)
# DB_DRIVER=sqlite

# 数据库主机地址；SQLite 可不设置
# DB_HOST=localhost

# 数据库端口；PostgreSQL 默认 5432，MySQL 默认 3306
# DB_PORT=5432

# 数据库用户名；SQLite 可不设置
# DB_USER=postgres

# 数据库密码；生产环境必须通过环境变量或密钥管理服务设置
# DB_PASSWORD=your-secure-password

# 数据库名称；SQLite 使用文件路径
# DB_NAME=./data/app.db

# 最大打开连接数
# DB_MAX_OPEN_CONNS=10

# 最大空闲连接数
# DB_MAX_IDLE_CONNS=5

# ==================== Redis 配置 ====================
# 是否启用 Redis (true/false)
# REDIS_ENABLED=false

# Redis 主机地址
# REDIS_HOST=localhost

# Redis 端口
# REDIS_PORT=6379

# Redis 密码
# REDIS_PASSWORD=

# Redis 数据库索引 (0-15)
# REDIS_DB=0

# Redis 连接池大小
# REDIS_POOL_SIZE=20

# Redis 最小空闲连接数
# REDIS_MIN_IDLE_CONNS=10

# Redis 最大重试次数
# REDIS_MAX_RETRIES=3

# Redis 连接超时时间(秒)
# REDIS_DIAL_TIMEOUT=5

# Redis 读取超时时间(秒)
# REDIS_READ_TIMEOUT=3

# Redis 写入超时时间(秒)
# REDIS_WRITE_TIMEOUT=3

# ==================== 服务器配置 ====================
# HTTP 服务器端口
# SERVER_PORT=9999

# 服务器运行模式 (debug, release, test)
# SERVER_MODE=release

# HTTP 读取超时时间(秒)
# SERVER_READ_TIMEOUT=10

# HTTP 写入超时时间(秒)
# SERVER_WRITE_TIMEOUT=10

# ==================== 日志配置 ====================
# 日志级别 (debug, info, warn, error)
# LOG_LEVEL=info

# 日志格式 (json, console)
# LOG_FORMAT=console

# 日志输出 (stdout, file, both)
# LOG_OUTPUT=stdout

# ==================== 国际化配置 ====================
# 默认语言
# I18N_DEFAULT=zh-CN

# 支持的语言列表 (逗号分隔)
# I18N_SUPPORTED=zh-CN,en-US

# ==================== 文件服务配置 ====================
# 文件服务配置在初始化 storage 时覆盖
# STORAGE_ENABLED=false
# STORAGE_FS_TYPE=os
# STORAGE_BASE_PATH=./data
# STORAGE_ENABLE_WATCH=false
# STORAGE_WATCH_BUFFER_SIZE=100

# ==================== CORS 配置 ====================
# CORS 配置在初始化 HTTP transport 时覆盖
# CORS_ENABLED=true
# CORS_ALLOW_ORIGINS=*
# CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization,X-Request-ID
# CORS_EXPOSE_HEADERS=X-Request-ID
# CORS_ALLOW_CREDENTIALS=false
# CORS_MAX_AGE=3600

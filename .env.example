# 环境变量配置文件示例
# 将此文件复制为 .env 并填入实际值。
# .env 文件不应提交到 Git；生产环境建议直接使用系统环境变量或密钥管理服务。
#
# 命名策略：
# - 配置覆盖默认使用 <APP_PREFIX>_APP_<MODULE>_<FIELD>。
# - 当前 AppPrefix=Rin，因此环境变量前缀为 RIN_APP，例如 RIN_APP_DB_HOST、RIN_APP_SERVER_PORT。
# - 未加前缀的 <MODULE>_<FIELD> 仍作为兼容 fallback，便于平滑迁移。
# - Auth token signing settings are configurable. Examples use placeholders only.

# ==================== 数据库配置 ====================
# 数据库驱动类型 (postgres, mysql, sqlite)
# RIN_APP_DB_DRIVER=sqlite

# 数据库主机地址；SQLite 可不设置
# RIN_APP_DB_HOST=localhost

# 数据库端口；PostgreSQL 默认 5432，MySQL 默认 3306
# RIN_APP_DB_PORT=5432

# 数据库用户名；SQLite 可不设置
# RIN_APP_DB_USER=postgres

# 数据库密码；生产环境必须通过环境变量或密钥管理服务设置
# RIN_APP_DB_PASSWORD=your-secure-password

# 数据库名称；SQLite 使用文件路径
# RIN_APP_DB_NAME=./data/app.db

# 最大打开连接数
# RIN_APP_DB_MAX_OPEN_CONNS=10

# 最大空闲连接数
# RIN_APP_DB_MAX_IDLE_CONNS=5

# ==================== Redis 配置 ====================
# 是否启用 Redis (true/false)
# RIN_APP_REDIS_ENABLED=false

# Redis 主机地址
# RIN_APP_REDIS_HOST=localhost

# Redis 端口
# RIN_APP_REDIS_PORT=6379

# Redis 密码
# RIN_APP_REDIS_PASSWORD=

# Redis 数据库索引 (0-15)
# RIN_APP_REDIS_DB=0

# Redis 连接池大小
# RIN_APP_REDIS_POOL_SIZE=20

# Redis 最小空闲连接数
# RIN_APP_REDIS_MIN_IDLE_CONNS=10

# Redis 最大重试次数
# RIN_APP_REDIS_MAX_RETRIES=3

# Redis 连接超时时间(秒)
# RIN_APP_REDIS_DIAL_TIMEOUT=5

# Redis 读取超时时间(秒)
# RIN_APP_REDIS_READ_TIMEOUT=3

# Redis 写入超时时间(秒)
# RIN_APP_REDIS_WRITE_TIMEOUT=3

# ==================== 服务器配置 ====================
# HTTP 服务器地址
# RIN_APP_SERVER_HOST=0.0.0.0

# HTTP 服务器端口
# RIN_APP_SERVER_PORT=9999

# 服务器运行模式 (debug, release, test)
# RIN_APP_SERVER_MODE=release

# HTTP 读取超时时间(秒)
# RIN_APP_SERVER_READ_TIMEOUT=10

# HTTP 写入超时时间(秒)
# RIN_APP_SERVER_WRITE_TIMEOUT=10

# HTTP 空闲连接超时时间(秒)
# RIN_APP_SERVER_IDLE_TIMEOUT=60

# ==================== 日志配置 ====================
# 日志级别 (debug, info, warn, error)
# RIN_APP_LOG_LEVEL=info

# 日志格式 (json, console)
# RIN_APP_LOG_FORMAT=console

# 控制台日志格式 (json, console)
# RIN_APP_LOG_CONSOLE_FORMAT=console

# 文件日志格式 (json, console)
# RIN_APP_LOG_FILE_FORMAT=json

# 日志输出 (stdout, file, both)
# RIN_APP_LOG_OUTPUT=stdout

# 日志文件路径
# RIN_APP_LOG_FILE_PATH=./logs/app.log

# 单个日志文件最大大小(MB)
# RIN_APP_LOG_MAX_SIZE=100

# 保留旧日志文件数量
# RIN_APP_LOG_MAX_BACKUPS=7

# 保留旧日志文件天数
# RIN_APP_LOG_MAX_AGE=30

# ==================== 国际化配置 ====================
# 默认语言
# RIN_APP_I18N_DEFAULT=zh-CN

# 支持的语言列表 (逗号分隔)
# RIN_APP_I18N_SUPPORTED=zh-CN,en-US

# 语言文件目录
# RIN_APP_I18N_MESSAGES_DIR=./configs/locales

# ==================== 初始化数据库配置 ====================
# 初始化脚本目录
# RIN_APP_INITDB_SCRIPT_DIR=./scripts

# 初始化锁文件
# RIN_APP_INITDB_LOCK_FILE=.initdb.lock

# 初始化脚本文件名前缀
# RIN_APP_INITDB_SCRIPT_FILE_PREFIX=init_

# ==================== 执行器配置 ====================
# 是否启用执行器 (true/false)
# RIN_APP_EXECUTOR_ENABLED=true

# ==================== 文件服务配置 ====================
# RIN_APP_STORAGE_ENABLED=false
# RIN_APP_STORAGE_FS_TYPE=os
# RIN_APP_STORAGE_BASE_PATH=./data
# RIN_APP_STORAGE_ENABLE_WATCH=false
# RIN_APP_STORAGE_WATCH_BUFFER_SIZE=100

# ==================== 插件配置 ====================
# RIN_APP_PLUGIN_ENABLED=false
# RIN_APP_PLUGIN_DEFAULT_TIMEOUT=10
# RIN_APP_PLUGIN_MAX_RESPONSE_BYTES=1048576
# RIN_APP_PLUGIN_INTERFACE_HTTP_ENABLED=false
# RIN_APP_PLUGIN_INTERFACE_HTTP_HOST=127.0.0.1
# RIN_APP_PLUGIN_INTERFACE_HTTP_PORT=18080
# RIN_APP_PLUGIN_INTERFACE_HTTP_PUBLIC_URL=http://127.0.0.1:18080
# RIN_APP_PLUGIN_INTERFACE_WS_PUBLIC_URL=ws://127.0.0.1:18080/plugin/v1/ws
# RIN_APP_PLUGIN_REGISTRATION_ENABLED=false
# RIN_APP_PLUGIN_REGISTRATION_EXPOSE_ON_MAIN_HTTP=false
# RIN_APP_PLUGIN_REGISTRATION_TOKEN=replace-with-registration-token

# ==================== IAM 配置 ====================
# RIN_APP_IAM_ENABLED=false
# RIN_APP_IAM_MODE=memory
# RIN_APP_IAM_DEFAULT_DENY=true

# ==================== Auth configuration ====================
# Auth token signing is now configurable. Placeholder only; do not commit real production secrets.
# RIN_APP_AUTH_TOKEN_SECRET=replace-with-at-least-32-character-secret
# RIN_APP_AUTH_TOKEN_TTL=86400

# ==================== CORS 配置 ====================
# RIN_APP_CORS_ENABLED=true
# RIN_APP_CORS_ALLOW_ORIGINS=*
# RIN_APP_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# RIN_APP_CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization,X-Request-ID
# RIN_APP_CORS_EXPOSE_HEADERS=X-Request-ID
# RIN_APP_CORS_ALLOW_CREDENTIALS=false
# RIN_APP_CORS_MAX_AGE=3600

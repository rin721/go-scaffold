# Remote deployment environment template.
# Copy this file to .env.deploy and fill in real values outside Git.
# Do not commit .env.deploy, private keys, tokens, passwords, or real host values.

# Deployment target.
DEPLOY_ENV=staging
DEPLOY_HOST=example.com
DEPLOY_PORT=22
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/go-scaffold

# Runtime on the remote host.
DEPLOY_COMPOSE_FILE=docker-compose.yml
DEPLOY_SERVICE=go-scaffold
DEPLOY_CONFIG_PATH=/opt/go-scaffold/configs/config.yaml

# Image to run on the remote host.
DEPLOY_IMAGE=ghcr.io/OWNER/go-scaffold:latest

# Post-deploy checks from the remote host or deployment runner.
DEPLOY_HEALTH_URL=http://127.0.0.1:9999/health
DEPLOY_READY_URL=http://127.0.0.1:9999/ready

# Keep SSH keys and registry tokens in GitHub Secrets, not in this file.
# Recommended GitHub Secrets for the remote deployment workflow:
# DEPLOY_ENV_FILE
# DEPLOY_SSH_KEY
# DEPLOY_SSH_KNOWN_HOSTS
# GHCR_USERNAME
# GHCR_TOKEN
